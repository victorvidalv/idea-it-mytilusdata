DATABASE_URL="local.db"
RESEND_API_KEY=
JWT_SECRET=
EMAIL_FROM=

# Admin Inicial (RBAC Dinámico)
# Este email se usa UNA vez para crear el primer administrador via: npm run create-admin
# Después de creado, los roles se gestionan exclusivamente desde el panel de administración
INITIAL_ADMIN_EMAIL=admin@tu-dominio.com

# Cloudflare Turnstile (CAPTCHA)
# Obtén tus claves en: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=
PUBLIC_TURNSTILE_SITE_KEY=

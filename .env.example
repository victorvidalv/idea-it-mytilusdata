# =============================================================================
# VARIABLES DE ENTORNO REQUERIDAS - Calculadora IT25I0032
# =============================================================================
# Copiar este archivo como .env y configurar los valores apropiados.
# IMPORTANTE: Nunca subir el archivo .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS
# -----------------------------------------------------------------------------
# URL de conexión a PostgreSQL
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
DATABASE_URL="postgresql://usuario:password@localhost:5432/calculadora_db"

# -----------------------------------------------------------------------------
# SEGURIDAD - TOKENS Y SECRETOS
# -----------------------------------------------------------------------------
# Secreto para firmar tokens JWT (mínimo 32 caracteres, usar valor aleatorio)
# Generar con: openssl rand -base64 48
JWT_SECRET="CAMBIAR_POR_VALOR_SEGURO_MINIMO_32_CARACTERES"

# Secreto para protección CSRF (mínimo 32 caracteres, usar valor aleatorio)
# Generar con: openssl rand -base64 48
CSRF_SECRET="CAMBIAR_POR_VALOR_SEGURO_MINIMO_32_CARACTERES"

# Token para acceso a API pública (opcional, para integraciones externas)
API_PUBLIC_TOKEN="CAMBIAR_POR_TOKEN_UNICO"

# -----------------------------------------------------------------------------
# ENTORNO
# -----------------------------------------------------------------------------
# Entorno de ejecución: development | production | test
NODE_ENV="development"

# -----------------------------------------------------------------------------
# PRÓXIMOS PASOS PARA PRODUCCIÓN
# -----------------------------------------------------------------------------
# 1. Generar secretos seguros:
#    openssl rand -base64 48  # Para cada SECRET
#
# 2. Configurar variables en plataforma de deploy (Vercel, Railway, etc.)
#
# 3. Verificar que .env está en .gitignore
#
# 4. Rotar secretos periódicamente
# =============================================================================

# Playwright E2E Test Credentials
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=your_password

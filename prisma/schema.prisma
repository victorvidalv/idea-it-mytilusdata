// --- SISTEMA DE REGISTRO DE MEDICIONES (V2.1) ---
// Configuración de Prisma con PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN
  EQUIPO
  PUBLICO
}

// --- TABLA DE USUARIOS ---
model Usuario {
  id            Int       @id @default(autoincrement())
  nombre        String
  email         String    @unique
  password_hash String
  rol           Rol       @default(PUBLICO)
  activo        Boolean   @default(true) // Para bloquear acceso sin borrar historial
  created_at    DateTime  @default(now())

  // Relaciones
  unidades          Unidad[]          @relation("creador_unidad")
  lugares           Lugar[]           @relation("creador_lugar")
  origenes          OrigenDato[]      @relation("creador_origen")
  mediciones        Medicion[]        @relation("registrador_medicion")
  ciclos            Ciclo[]           @relation("creador_ciclo")
  apiKeys           ApiKey[]          @relation("creador_apikey")

  @@map("usuarios")
}

// --- TABLA DE UNIDADES ---
model Unidad {
  id            Int       @id @default(autoincrement())
  nombre        String
  sigla         String
  creado_por_id Int?
  deleted_at    DateTime? // Si tiene fecha, está borrado lógico

  // Relaciones
  creador    Usuario?   @relation("creador_unidad", fields: [creado_por_id], references: [id])
  mediciones Medicion[] @relation("unidad_medicion")

  @@map("unidades")
}

// --- TABLA DE LUGARES ---
model Lugar {
  id            Int       @id @default(autoincrement())
  nombre        String
  nota          String?
  latitud       Decimal?
  longitud      Decimal?
  creado_por_id Int?
  created_at    DateTime  @default(now())
  deleted_at    DateTime? // Si tiene fecha, está borrado lógico

  // Relaciones
  creador    Usuario?   @relation("creador_lugar", fields: [creado_por_id], references: [id])
  mediciones Medicion[] @relation("lugar_medicion")
  ciclos     Ciclo[]    @relation("ciclos_lugar")

  @@map("lugares")
}

// --- TABLA DE TIPOS DE REGISTRO ---
model TipoRegistro {
  id          Int     @id @default(autoincrement())
  codigo      String  @unique // PRUEBA, MUESTRA, DATO_PREVIO
  descripcion String?

  // Relaciones
  mediciones Medicion[] @relation("tipo_medicion")

  @@map("tipos_registro")
}

// --- TABLA DE ORÍGENES DE DATOS ---
model OrigenDato {
  id            Int       @id @default(autoincrement())
  nombre        String
  descripcion   String?
  creado_por_id Int?
  deleted_at    DateTime?

  // Relaciones
  creador    Usuario?   @relation("creador_origen", fields: [creado_por_id], references: [id])
  mediciones Medicion[] @relation("origen_medicion")

  @@map("origen_datos")
}

// --- TABLA DE MEDICIONES ---
model Medicion {
  id                Int       @id @default(autoincrement())
  valor             Decimal
  fecha_medicion    DateTime
  lugar_id          Int
  unidad_id         Int
  tipo_id           Int
  origen_id         Int
  registrado_por_id Int
  ciclo_id          Int?      // Ciclo al que pertenece esta medición (opcional para datos históricos)
  notas             String?   // Campo opcional para comentarios adicionales
  
  // Auditoría básica de fila
  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime? // Crucial para soft delete. Nunca hacer DELETE FROM

  // Relaciones
  lugar          Lugar        @relation("lugar_medicion", fields: [lugar_id], references: [id])
  unidad         Unidad       @relation("unidad_medicion", fields: [unidad_id], references: [id])
  tipo           TipoRegistro @relation("tipo_medicion", fields: [tipo_id], references: [id])
  origen         OrigenDato   @relation("origen_medicion", fields: [origen_id], references: [id])
  registrado_por Usuario      @relation("registrador_medicion", fields: [registrado_por_id], references: [id])
  ciclo          Ciclo?       @relation("ciclo_medicion", fields: [ciclo_id], references: [id])

  @@index([fecha_medicion])
  @@index([lugar_id])
  @@index([unidad_id])
  @@index([tipo_id])
  @@index([origen_id])
  @@index([registrado_por_id])
  @@index([ciclo_id])
  @@index([deleted_at])
  @@map("mediciones")
}

// --- TABLA DE CICLOS ---
model Ciclo {
  id                   Int       @id @default(autoincrement())
  nombre               String    // Ej: "Ciclo 2025-1", "Temporada Primavera 2025"
  fecha_siembra        DateTime  // Fecha de inicio del ciclo (siembra)
  fecha_finalizacion   DateTime? // Fecha de término (opcional, null si está activo)
  lugar_id             Int       // Relación con el centro (lugar)
  activo               Boolean   @default(true) // Solo un ciclo activo por lugar
  notas                String?
  
  // Auditoría
  creado_por_id        Int?
  created_at           DateTime  @default(now())
  deleted_at           DateTime? // Soft delete
  
  // Relaciones
  lugar                Lugar     @relation("ciclos_lugar", fields: [lugar_id], references: [id])
  creador              Usuario?  @relation("creador_ciclo", fields: [creado_por_id], references: [id])
  mediciones           Medicion[] @relation("ciclo_medicion")
  
  @@index([lugar_id])
  @@index([activo])
  @@index([fecha_siembra])
  @@index([deleted_at])
  @@map("ciclos")
}

// --- TABLA DE API KEYS ---
model ApiKey {
  id            Int       @id @default(autoincrement())
  nombre        String    // Identificador legible (ej: "App Móvil", "Integración SERNAP")
  key_hash      String    @unique // Hash SHA-256 de la clave
  key_prefix    String    // Primeros 8 caracteres para identificación visual
  permisos      String[]  // ["lugares:read", "lugares:write", "ciclos:read", etc.]
  creado_por_id Int
  activa        Boolean   @default(true)
  ultimo_uso    DateTime?
  created_at    DateTime  @default(now())
  revocada_at   DateTime?
  
  // Relaciones
  creador       Usuario   @relation("creador_apikey", fields: [creado_por_id], references: [id])
  
  @@index([key_hash])
  @@index([activa])
  @@map("api_keys")
}

                                       class="w-full h-2 bg-blue-200 rounded-lg appearance-none cursor-pointer">
                            </div>
                            <div class="grid md:grid-cols-2 gap-8">
                                <!-- Centro 1 -->
                                <div class="space-y-4">
                                    <div class="bg-blue-50 p-4 rounded-lg shadow-sm">
                                        <p class="text-gray-700">Velocidad de crecimiento (Centro 1):</p>
                                        <p id="velocidad1" class="text-2xl font-bold text-blue-600"></p>
                                    </div>
                                    <div class="bg-blue-50 p-4 rounded-lg shadow-sm">
                                        <p class="text-gray-700">Aceleración (Centro 1):</p>
                                        <p id="aceleracion1" class="text-2xl font-bold text-blue-600"></p>
                                    </div>
                                </div>
                                <!-- Centro 2 -->
                                <div class="space-y-4">
                                    <div class="bg-green-50 p-4 rounded-lg shadow-sm">
                                        <p class="text-gray-700">Velocidad de crecimiento (Centro 2):</p>
                                        <p id="velocidad2" class="text-2xl font-bold text-green-600"></p>
                                    </div>
                                    <div class="bg-green-50 p-4 rounded-lg shadow-sm">
                                        <p class="text-gray-700">Aceleración (Centro 2):</p>
                                        <p id="aceleracion2" class="text-2xl font-bold text-green-600"></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Predicción -->
                    <div class="bg-white shadow-lg rounded-lg p-6 mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-2xl font-semibold text-gray-800">Predicción de Crecimiento</h2>
                            <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">Estimación</div>
                        </div>
                        <div class="bg-gray-50 p-4 rounded-lg">
                            <label for="tamanoObjetivo" class="block text-gray-700 font-medium mb-2">
                                Tamaño Objetivo: <span id="tamanoObjetivoValor" class="text-blue-600 font-bold">1.0</span> mm
                            </label>
                            <input type="range" 
                                   id="tamanoObjetivo" 
                                   name="tamanoObjetivo" 
                                   min="1" 
                                   max="20" 
                                   step="0.1" 
                                   value="1.0"
                                   class="w-full h-2 bg-blue-200 rounded-lg appearance-none cursor-pointer mb-4">
                            
                            <div class="grid md:grid-cols-2 gap-6">
                                <!-- Predicción Centro 1 -->
                                <div class="bg-gradient-to-br from-blue-50 to-blue-100 p-6 rounded-xl shadow-sm">
                                    <h3 class="text-xl font-semibold mb-4 text-blue-800" id="prediccion-nombre1">Centro 1</h3>
                                    <p id="prediccion1" class="text-lg font-medium text-blue-900"></p>
                                    <div id="maxInfo1" class="mt-4 p-4 bg-yellow-50 rounded-lg border border-yellow-200 hidden">
                                        <p class="text-yellow-800">
                                            <span class="font-bold">Nota:</span> 
                                            El tamaño máximo teórico es <span class="font-bold tamanoMax1"></span> mm.
                                            <br>
                                            Para alcanzar el 99% de este tamaño se necesitarían aproximadamente 
                                            <span class="font-bold diasMax1"></span> días.
                                        </p>
                                    </div>
                                </div>
                                <!-- Predicción Centro 2 -->
                                <div class="bg-gradient-to-br from-green-50 to-green-100 p-6 rounded-xl shadow-sm">
                                    <h3 class="text-xl font-semibold mb-4 text-green-800" id="prediccion-nombre2">Centro 2</h3>
                                    <p id="prediccion2" class="text-lg font-medium text-green-900"></p>
                                    <div id="maxInfo2" class="mt-4 p-4 bg-yellow-50 rounded-lg border border-yellow-200 hidden">
                                        <p class="text-yellow-800">
                                            <span class="font-bold">Nota:</span> 
                                            El tamaño máximo teórico es <span class="font-bold tamanoMax2"></span> mm.
                                            <br>
                                            Para alcanzar el 99% de este tamaño se necesitarían aproximadamente 
                                            <span class="font-bold diasMax2"></span> días.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Tabla Comparativa -->
                    <div class="bg-white shadow-lg rounded-lg p-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-2xl font-semibold text-gray-800">Análisis Comparativo</h2>
                            <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">Estadísticas</div>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="min-w-full divide-y divide-gray-300">
                                <thead>
                                    <tr>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                            Métrica
                                        </th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                            Centro 1
                                        </th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                            Centro 2
                                        </th>
                                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                            Diferencia
                                        </th>
                                    </tr>
                                </thead>
                                <tbody id="comparison-table" class="bg-white divide-y divide-gray-200">
                                    <!-- Los datos se llenarán dinámicamente -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    // Fecha de inicio fija
    const fechaInicio = new Date('2024-01-01');
    let chart = null;
    
    // Variables globales para almacenar mediciones
    window.mediciones1 = [];
    window.mediciones2 = [];

    let map = null;
    let marker1 = null;
    let marker2 = null;
    let line = null;

    function inicializarMapa() {
        if (map) map.remove();
        
        map = L.map('map').setView([40.4168, -3.7038], 6); // Vista inicial en España
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);
    }

    function actualizarMapa(lat1, lng1, lat2, lng2, nombre1, nombre2) {
        if (!map) inicializarMapa();
        
        // Limpiar marcadores y línea anteriores
        if (marker1) marker1.remove();
        if (marker2) marker2.remove();
        if (line) line.remove();
        
        // Si no hay coordenadas válidas, salir
        if (!lat1 || !lng1 || !lat2 || !lng2) return;
        
        // Crear marcadores
        marker1 = L.marker([lat1, lng1])
            .bindPopup(nombre1)
            .addTo(map);
        
        marker2 = L.marker([lat2, lng2])
            .bindPopup(nombre2)
            .addTo(map);
        
        // Crear línea entre puntos
        line = L.polyline([[lat1, lng1], [lat2, lng2]], {
            color: 'red',
            weight: 2,
            opacity: 0.7,
            dashArray: '5, 10'
        }).addTo(map);
        
        // Ajustar vista para mostrar ambos puntos
        const bounds = L.latLngBounds([
            [lat1, lng1],
            [lat2, lng2]
        ]);
        map.fitBounds(bounds, { padding: [50, 50] });
    }

    // Función para obtener mediciones de un centro
    async function obtenerMediciones(centroId) {
        try {
            const response = await fetch(`/centers/${centroId}/measurements`);
            if (!response.ok) throw new Error('Error al obtener mediciones');
            const mediciones = await response.json();
            return mediciones.map(m => ({
                ...m,
                dia: Math.floor((new Date(m.measurement_date) - fechaInicio) / (1000 * 60 * 60 * 24))
            }));
        } catch (error) {
            console.error('Error:', error);
            return [];
        }
    }

    // Función para obtener información geográfica del centro
    async function obtenerInfoCentro(centroId) {
        try {
            const response = await fetch(`/centers/${centroId}/info`);
            if (!response.ok) throw new Error('Error al obtener información del centro');
            return await response.json();
        } catch (error) {
            console.error('Error:', error);
            return null;
        }
    }

    // Función para calcular distancia entre dos puntos
    function calcularDistancia(lat1, lon1, lat2, lon2) {
        if (!lat1 || !lon1 || !lat2 || !lon2) return null;
        
        const R = 6371; // Radio de la Tierra en km
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLon = (lon2 - lon1) * Math.PI / 180;
        
        const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                 Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * 
                 Math.sin(dLon/2) * Math.sin(dLon/2);
        
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        return R * c;
    }

    // Función para actualizar información geográfica
    async function actualizarInfoGeografica(centroId, numero) {
        const info = await obtenerInfoCentro(centroId);
        if (info) {
            document.getElementById(`lat${numero}`).textContent = info.latitude ? info.latitude.toFixed(6) : '-';
            document.getElementById(`lng${numero}`).textContent = info.longitude ? info.longitude.toFixed(6) : '-';
            document.getElementById(`address${numero}`).textContent = info.address || info.location || '-';
            document.getElementById(`geo-nombre${numero}`).textContent = info.name;
            
            // Actualizar enlace a Google Maps
            if (info.latitude && info.longitude) {
                const mapsUrl = `https://www.google.com/maps?q=${info.latitude},${info.longitude}`;
                document.getElementById(`maps-link${numero}`).href = mapsUrl;
                document.getElementById(`maps-link${numero}`).classList.remove('hidden');
            } else {
                document.getElementById(`maps-link${numero}`).classList.add('hidden');
            }

            // Calcular y actualizar distancia si ambos centros tienen coordenadas
            if (numero === 2) {
                const lat1 = parseFloat(document.getElementById('lat1').textContent);
                const lng1 = parseFloat(document.getElementById('lng1').textContent);
                const lat2 = parseFloat(document.getElementById('lat2').textContent);
                const lng2 = parseFloat(document.getElementById('lng2').textContent);
                
                const distancia = calcularDistancia(lat1, lng1, lat2, lng2);
                const distanciaElement = document.getElementById('distancia');
                
                if (distancia) {
                    distanciaElement.textContent = `${distancia.toFixed(2)} km`;
                } else {
                    distanciaElement.textContent = 'No disponible';
                }
            }

            // Actualizar mapa cuando se tenga la información del segundo centro
            if (numero === 2) {
                const lat1 = parseFloat(document.getElementById('lat1').textContent);
                const lng1 = parseFloat(document.getElementById('lng1').textContent);
                const lat2 = parseFloat(document.getElementById('lat2').textContent);
                const lng2 = parseFloat(document.getElementById('lng2').textContent);
                const nombre1 = document.getElementById('geo-nombre1').textContent;
                const nombre2 = document.getElementById('geo-nombre2').textContent;
                
                actualizarMapa(lat1, lng1, lat2, lng2, nombre1, nombre2);
            }
        }
    }

    // Función sigmoidal
    function sigmoidal(x, L, k, x0) {
        return L / (1 + Math.exp(-k * (x - x0)));
    }

    // Ajuste sigmoidal
    function ajustarSigmoidal(datos) {
        if (!datos || datos.length === 0) return null;
        
        const L = Math.max(...datos.map(r => r.size)) * 1.2;
        const k = 0.1;
        const x0 = datos[Math.floor(datos.length / 2)].dia;
        return { L, k, x0 };
    }

    // Cálculo de R²
    function calcularRcuadrado(datos, L, k, x0) {
        if (!datos || datos.length < 2) return 0;
        
        const n = datos.length;
        const media = datos.reduce((sum, d) => sum + d.size, 0) / n;
        
        let ssTot = 0, ssRes = 0;
        datos.forEach(d => {
            const yPred = sigmoidal(d.dia, L, k, x0);
            ssTot += Math.pow(d.size - media, 2);
            ssRes += Math.pow(d.size - yPred, 2);
        });
        
        return ssTot === 0 ? 0 : 1 - (ssRes / ssTot);
    }

    // Primera derivada (velocidad de crecimiento)
    function primeraDerivada(x, L, k, x0) {
        const exp = Math.exp(-k * (x - x0));
        return (L * k * exp) / Math.pow(1 + exp, 2);
    }

    // Segunda derivada (aceleración)
    function segundaDerivada(x, L, k, x0) {
        const exp = Math.exp(-k * (x - x0));
        return (L * k * k * exp * (exp - 1)) / Math.pow(1 + exp, 3);
    }

    // Calcular días para alcanzar porcentaje del máximo
    function calcularDiasParaPorcentaje(porcentaje, L, k, x0) {
        if (!L || !k || !x0 || porcentaje <= 0 || porcentaje >= 100) return null;
        
        const proporcion = porcentaje / 100;
        return x0 - (1/k) * Math.log((1/proporcion) - 1);
    }

    // Predicción de días
    function predecirDia(tamanoObjetivo, L, k, x0) {
        if (tamanoObjetivo <= 0 || !L || !k || !x0) return null;
        if (tamanoObjetivo >= L) return null;
        
        return x0 - (1/k) * Math.log(L/tamanoObjetivo - 1);
    }

    // Función para actualizar velocidades y aceleraciones
    function actualizarVelocidades(dia, params1, params2) {
        if (params1) {
            const v1 = primeraDerivada(dia, params1.L, params1.k, params1.x0);
            const a1 = segundaDerivada(dia, params1.L, params1.k, params1.x0);
            document.getElementById('velocidad1').textContent = `${v1.toFixed(2)} mm/día`;
            document.getElementById('aceleracion1').textContent = `${a1.toFixed(2)} mm/día²`;
        }
        
        if (params2) {
            const v2 = primeraDerivada(dia, params2.L, params2.k, params2.x0);
            const a2 = segundaDerivada(dia, params2.L, params2.k, params2.x0);
            document.getElementById('velocidad2').textContent = `${v2.toFixed(2)} mm/día`;
            document.getElementById('aceleracion2').textContent = `${a2.toFixed(2)} mm/día²`;
        }
    }

    // Función para actualizar predicciones
    function actualizarPredicciones(tamanoObjetivo, params1, params2, nombre1, nombre2) {
        // Predicción Centro 1
        if (params1) {
            if (tamanoObjetivo >= params1.L) {
                document.getElementById('prediccion1').innerHTML = 
                    `<span class="text-red-600 font-bold">Advertencia:</span> El tamaño objetivo (${tamanoObjetivo} mm) excede el máximo teórico.`;
                document.getElementById('maxInfo1').querySelector('.tamanoMax1').textContent = params1.L.toFixed(2);
                document.getElementById('maxInfo1').querySelector('.diasMax1').textContent = 
                    calcularDiasParaPorcentaje(99, params1.L, params1.k, params1.x0).toFixed(0);
                document.getElementById('maxInfo1').classList.remove('hidden');
            } else {
                const dias1 = predecirDia(tamanoObjetivo, params1.L, params1.k, params1.x0);
                const fecha1 = new Date(fechaInicio);
                fecha1.setDate(fecha1.getDate() + Math.round(dias1));
                document.getElementById('prediccion1').textContent = 
                    `Día aproximado = ${dias1.toFixed(0)} (${fecha1.toLocaleDateString()})`;
                document.getElementById('maxInfo1').classList.add('hidden');
            }
        }

        // Predicción Centro 2
        if (params2) {
            if (tamanoObjetivo >= params2.L) {
                document.getElementById('prediccion2').innerHTML = 
                    `<span class="text-red-600 font-bold">Advertencia:</span> El tamaño objetivo (${tamanoObjetivo} mm) excede el máximo teórico.`;
                document.getElementById('maxInfo2').querySelector('.tamanoMax2').textContent = params2.L.toFixed(2);
                document.getElementById('maxInfo2').querySelector('.diasMax2').textContent = 
                    calcularDiasParaPorcentaje(99, params2.L, params2.k, params2.x0).toFixed(0);
                document.getElementById('maxInfo2').classList.remove('hidden');
            } else {
                const dias2 = predecirDia(tamanoObjetivo, params2.L, params2.k, params2.x0);
                const fecha2 = new Date(fechaInicio);
                fecha2.setDate(fecha2.getDate() + Math.round(dias2));
                document.getElementById('prediccion2').textContent = 
                    `Día aproximado = ${dias2.toFixed(0)} (${fecha2.toLocaleDateString()})`;
                document.getElementById('maxInfo2').classList.add('hidden');
            }
        }

        // Actualizar nombres en predicciones
        document.getElementById('prediccion-nombre1').textContent = nombre1;
        document.getElementById('prediccion-nombre2').textContent = nombre2;
    }

    // Función para actualizar comparación
    async function actualizarComparacion() {
        const centro1Id = document.getElementById('centro1').value;
        const centro2Id = document.getElementById('centro2').value;

        if (!centro1Id || !centro2Id) return;

        const nombre1 = document.getElementById('centro1').options[document.getElementById('centro1').selectedIndex].text;
        const nombre2 = document.getElementById('centro2').options[document.getElementById('centro2').selectedIndex].text;

        document.getElementById('nombre-centro1').textContent = nombre1;
        document.getElementById('nombre-centro2').textContent = nombre2;

        // Actualizar nombres en las tablas de coordenadas
        document.getElementById('coord-nombre1').textContent = nombre1;
        document.getElementById('coord-nombre2').textContent = nombre2;

        // Actualizar información geográfica
        await Promise.all([
            actualizarInfoGeografica(centro1Id, 1),
            actualizarInfoGeografica(centro2Id, 2)
        ]);

        // Obtener y almacenar mediciones globalmente
        window.mediciones1 = await obtenerMediciones(centro1Id);
        window.mediciones2 = await obtenerMediciones(centro2Id);

        const params1 = ajustarSigmoidal(window.mediciones1);
        const params2 = ajustarSigmoidal(window.mediciones2);

        // Actualizar funciones y R²
        if (params1) {
            document.getElementById('funcion1').innerHTML =
                `\\[ f(x) = \\frac{${params1.L.toFixed(2)}}{1+e^{-\\,${params1.k.toFixed(3)}(x- ${params1.x0.toFixed(1)})}} \\]`;
            const r2_1 = calcularRcuadrado(window.mediciones1, params1.L, params1.k, params1.x0);
            document.getElementById('r2-centro1').textContent = `R² = ${(r2_1 * 100).toFixed(1)}%`;
        }

        if (params2) {
            document.getElementById('funcion2').innerHTML =
                `\\[ f(x) = \\frac{${params2.L.toFixed(2)}}{1+e^{-\\,${params2.k.toFixed(3)}(x- ${params2.x0.toFixed(1)})}} \\]`;
            const r2_2 = calcularRcuadrado(window.mediciones2, params2.L, params2.k, params2.x0);
            document.getElementById('r2-centro2').textContent = `R² = ${(r2_2 * 100).toFixed(1)}%`;
        }

        // Actualizar MathJax
        MathJax.typesetPromise([document.getElementById('funcion1'), document.getElementById('funcion2')]);

        // Destruir gráfico anterior si existe
        if (chart) chart.destroy();

        // Crear nuevo gráfico
        const ctx = document.getElementById('comparison-chart').getContext('2d');
        let maxDias = Math.max(
            Math.max(...window.mediciones1.map(m => m.dia)),
            Math.max(...window.mediciones2.map(m => m.dia))
        );

        chart = new Chart(ctx, {
            type: 'scatter',
            data: {
                datasets: [
                    {
                        label: document.getElementById('centro1').options[document.getElementById('centro1').selectedIndex].text,
                        data: window.mediciones1.map(m => ({ x: m.dia, y: m.size })),
                        backgroundColor: 'rgba(59, 130, 246, 0.8)',
                    },
                    params1 ? {
                        label: 'Ajuste Centro 1',
                        data: Array.from({ length: 100 }, (_, i) => {
                            const x = i * (maxDias / 100);
                            return { x, y: sigmoidal(x, params1.L, params1.k, params1.x0) };
                        }),
                        type: 'line',
                        borderColor: 'rgba(59, 130, 246, 0.8)',
                        borderWidth: 2,
                        fill: false,
                        pointRadius: 0
                    } : null,
                    {
                        label: document.getElementById('centro2').options[document.getElementById('centro2').selectedIndex].text,
                        data: window.mediciones2.map(m => ({ x: m.dia, y: m.size })),
                        backgroundColor: 'rgba(16, 185, 129, 0.8)',
                    },
                    params2 ? {
                        label: 'Ajuste Centro 2',
                        data: Array.from({ length: 100 }, (_, i) => {
                            const x = i * (maxDias / 100);
                            return { x, y: sigmoidal(x, params2.L, params2.k, params2.x0) };
                        }),
                        type: 'line',
                        borderColor: 'rgba(16, 185, 129, 0.8)',
                        borderWidth: 2,
                        fill: false,
                        pointRadius: 0
                    } : null,
                ].filter(Boolean)
            },
            options: {
                scales: {
                    x: {
                        type: 'linear',
                        position: 'bottom',
                        title: { display: true, text: 'Día' }
                    },
                    y: {
                        title: { display: true, text: 'Tamaño (mm)' }
                    }
                },
                plugins: {
                    title: {
                        display: true,
                        text: 'Comparación de Crecimiento'
                    }
                }
            }
        });

        // Actualizar tabla comparativa
        const tabla = document.getElementById('comparison-table');
        tabla.innerHTML = '';

        if (params1 && params2) {
            const metricas = [
                {
                    nombre: 'Tamaño máximo estimado (mm)',
                    valor1: params1.L.toFixed(1),
                    valor2: params2.L.toFixed(1),
                    diferencia: (params1.L - params2.L).toFixed(1)
                },
                {
                    nombre: 'Tasa de crecimiento',
                    valor1: params1.k.toFixed(3),
                    valor2: params2.k.toFixed(3),
                    diferencia: (params1.k - params2.k).toFixed(3)
                },
                {
                    nombre: 'Punto de inflexión (días)',
                    valor1: params1.x0.toFixed(1),
                    valor2: params2.x0.toFixed(1),
                    diferencia: (params1.x0 - params2.x0).toFixed(1)
                }
            ];

            metricas.forEach(metrica => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                        ${metrica.nombre}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-blue-600 font-medium">
                        ${metrica.valor1}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600 font-medium">
                        ${metrica.valor2}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm ${parseFloat(metrica.diferencia) > 0 ? 'text-green-600' : 'text-red-600'} font-medium">
                        ${metrica.diferencia}
                    </td>
                `;
                tabla.appendChild(tr);
            });
        }

        // Actualizar tablas de coordenadas
        const tabla1 = document.getElementById('coord-table1');
        const tabla2 = document.getElementById('coord-table2');
        
        // Limpiar tablas
        tabla1.innerHTML = '';
        tabla2.innerHTML = '';
        
        // Llenar tabla 1
        window.mediciones1.sort((a, b) => a.dia - b.dia).forEach(m => {
            const tr = document.createElement('tr');
            const fecha = new Date(m.measurement_date);
            tr.innerHTML = `
                <td class="px-4 py-2 text-sm text-gray-900">${m.dia}</td>
                <td class="px-4 py-2 text-sm text-gray-900">${fecha.toLocaleDateString()}</td>
                <td class="px-4 py-2 text-sm text-blue-600 font-medium">${m.size.toFixed(2)}</td>
            `;
            tabla1.appendChild(tr);
        });
        
        // Llenar tabla 2
        window.mediciones2.sort((a, b) => a.dia - b.dia).forEach(m => {
            const tr = document.createElement('tr');
            const fecha = new Date(m.measurement_date);
            tr.innerHTML = `
                <td class="px-4 py-2 text-sm text-gray-900">${m.dia}</td>
                <td class="px-4 py-2 text-sm text-gray-900">${fecha.toLocaleDateString()}</td>
                <td class="px-4 py-2 text-sm text-green-600 font-medium">${m.size.toFixed(2)}</td>
            `;
            tabla2.appendChild(tr);
        });

        // Configurar slider de días
        maxDias = Math.max(
            Math.max(...window.mediciones1.map(m => m.dia)),
            Math.max(...window.mediciones2.map(m => m.dia))
        );
        const diaDerivada = document.getElementById('diaDerivada');
        diaDerivada.max = maxDias * 2;
        diaDerivada.value = maxDias / 2;
        document.getElementById('diaSeleccionado').textContent = diaDerivada.value;

        // Actualizar velocidades iniciales
        actualizarVelocidades(parseInt(diaDerivada.value), params1, params2);

        // Actualizar predicciones iniciales
        const tamanoObjetivo = parseFloat(document.getElementById('tamanoObjetivo').value);
        actualizarPredicciones(tamanoObjetivo, params1, params2, nombre1, nombre2);
    }

    // Event listeners
    document.getElementById('centro1').addEventListener('change', actualizarComparacion);
    document.getElementById('centro2').addEventListener('change', actualizarComparacion);
    
    document.getElementById('diaDerivada').addEventListener('input', function() {
        const dia = parseInt(this.value);
        document.getElementById('diaSeleccionado').textContent = dia;
        const centro1Id = document.getElementById('centro1').value;
        const centro2Id = document.getElementById('centro2').value;
        if (centro1Id && centro2Id) {
            const params1 = ajustarSigmoidal(window.mediciones1);
            const params2 = ajustarSigmoidal(window.mediciones2);
            actualizarVelocidades(dia, params1, params2);
        }
    });

    document.getElementById('tamanoObjetivo').addEventListener('input', function() {
        const tamanoObjetivo = parseFloat(this.value);
        document.getElementById('tamanoObjetivoValor').textContent = tamanoObjetivo.toFixed(1);
        const centro1Id = document.getElementById('centro1').value;
        const centro2Id = document.getElementById('centro2').value;
        if (centro1Id && centro2Id) {
            const params1 = ajustarSigmoidal(window.mediciones1);
            const params2 = ajustarSigmoidal(window.mediciones2);
            const nombre1 = document.getElementById('centro1').options[document.getElementById('centro1').selectedIndex].text;
            const nombre2 = document.getElementById('centro2').options[document.getElementById('centro2').selectedIndex].text;
            actualizarPredicciones(tamanoObjetivo, params1, params2, nombre1, nombre2);
        }
    });

    // Inicializar mapa cuando se carga la página
    document.addEventListener('DOMContentLoaded', inicializarMapa);
</script>


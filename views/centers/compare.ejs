                        </div>
                        <div class="grid md:grid-cols-2 gap-6">
                            <!-- Ubicación Centro 1 -->
                            <div class="bg-gradient-to-br from-blue-50 to-blue-100 p-6 rounded-xl shadow-sm">
                                <h3 class="text-lg font-semibold mb-3 text-blue-800" id="geo-nombre1">Centro 1</h3>
                                <div class="space-y-3">

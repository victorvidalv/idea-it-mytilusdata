                                <h3 class="text-xl font-semibold mb-4 text-blue-800" id="nombre-centro1">Centro 1</h3>
                                <div id="funcion1" class="text-2xl font-medium text-blue-900 mb-2"></div>
                                <p id="r2-centro1" class="text-sm text-blue-600"></p>
                            </div>
                            <!-- Centro 2 -->
                            <div class="bg-gradient-to-br from-green-50 to-green-100 p-6 rounded-xl shadow-sm">
                                <h3 class="text-xl font-semibold mb-4 text-green-800" id="nombre-centro2">Centro 2</h3>
                                <div id="funcion2" class="text-2xl font-medium text-green-900 mb-2"></div>
                                <p id="r2-centro2" class="text-sm text-green-600"></p>
                            </div>
                        </div>
                    </div>

                    <!-- Velocidad de Crecimiento -->
                    <div class="bg-white shadow-lg rounded-lg p-6 mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-2xl font-semibold text-gray-800">Velocidad de Crecimiento</h2>
                            <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">Análisis</div>
                        </div>
                        <div class="bg-gray-50 p-6 rounded-lg">

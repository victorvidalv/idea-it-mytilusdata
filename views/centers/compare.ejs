<%- include('../partials/header') %>

<div class="min-h-screen bg-gray-100">
    <div class="py-10">
        <header>
            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                <div class="md:flex md:items-center md:justify-between">
                    <div class="min-w-0 flex-1">
                        <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight">
                            Comparación de Centros
                        </h2>
                        <p class="mt-1 max-w-2xl text-sm text-gray-500">
                            Selecciona dos centros para comparar su crecimiento
                        </p>
                    </div>
                    <div class="mt-4 flex md:ml-4 md:mt-0">
                        <a href="/centers"
                            class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                            Volver a Centros
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <main>
            <div class="mx-auto max-w-7xl sm:px-6 lg:px-8">
                <div class="px-4 py-8 sm:px-0">
                    <!-- Selección de Centros -->
                    <div class="bg-white shadow-lg rounded-lg p-6 mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-2xl font-semibold text-gray-800">Selección de Centros</h2>
                            <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">Comparación</div>
                        </div>

                        <div class="grid md:grid-cols-2 gap-6">
                            <!-- Centro 1 -->
                            <div>
                                <label for="centro1" class="block text-sm font-medium text-gray-700 mb-2">
                                    Centro 1
                                </label>
                                <select id="centro1" class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500">
                                    <option value="">Selecciona un centro...</option>
                                    <% centers.forEach(function(center) { %>
                                        <option value="<%= center.id %>"><%= center.name %></option>
                                    <% }); %>
                                </select>
                            </div>

                            <!-- Centro 2 -->
                            <div>
                                <label for="centro2" class="block text-sm font-medium text-gray-700 mb-2">
                                    Centro 2
                                </label>
                                <select id="centro2" class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500">
                                    <option value="">Selecciona un centro...</option>
                                    <% centers.forEach(function(center) { %>
                                        <option value="<%= center.id %>"><%= center.name %></option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Coordenadas de los Centros -->
                    <div class="bg-white shadow-lg rounded-lg p-6 mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-2xl font-semibold text-gray-800">Coordenadas de los Centros</h2>
                            <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">Datos</div>
                        </div>
                        <div class="grid md:grid-cols-2 gap-6">
                            <!-- Coordenadas Centro 1 -->
                            <div>
                                <h3 class="text-lg font-semibold mb-3 text-blue-800" id="coord-nombre1">Centro 1</h3>
                                <div class="overflow-x-auto">
                                    <table class="min-w-full divide-y divide-gray-200">
                                        <thead class="bg-gray-50">
                                            <tr>
                                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Día</th>
                                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
                                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Tamaño (mm)</th>
                                            </tr>
                                        </thead>
                                        <tbody id="coord-table1" class="bg-white divide-y divide-gray-200">
                                            <!-- Se llenará dinámicamente -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <!-- Coordenadas Centro 2 -->
                            <div>
                                <h3 class="text-lg font-semibold mb-3 text-green-800" id="coord-nombre2">Centro 2</h3>
                                <div class="overflow-x-auto">
                                    <table class="min-w-full divide-y divide-gray-200">
                                        <thead class="bg-gray-50">
                                            <tr>
                                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Día</th>
                                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Fecha</th>
                                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Tamaño (mm)</th>
                                            </tr>
                                        </thead>
                                        <tbody id="coord-table2" class="bg-white divide-y divide-gray-200">
                                            <!-- Se llenará dinámicamente -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Distancia entre Centros -->
                    <div class="bg-white shadow-lg rounded-lg p-6 mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-2xl font-semibold text-gray-800">Distancia entre Centros</h2>
                            <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">Geolocalización</div>
                        </div>
                        <div class="bg-gradient-to-br from-gray-50 to-gray-100 p-6 rounded-xl shadow-sm">
                            <p class="text-lg text-gray-700 mb-2">Distancia en línea recta:</p>
                            <p id="distancia" class="text-3xl font-bold text-blue-900">-</p>

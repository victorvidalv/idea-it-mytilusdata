                    <!-- Mapa de Centros -->
                    <div class="bg-white shadow-lg rounded-lg p-6 mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-2xl font-semibold text-gray-800">Mapa de Centros</h2>
                            <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">Geolocalización</div>
                        </div>
                        <div id="map" class="h-96 w-full rounded-xl"></div>
                    </div>

                    <!-- Gráfico Comparativo -->
                    <div class="bg-white shadow-lg rounded-lg p-6 mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <h2 class="text-2xl font-semibold text-gray-800">Comparación de Crecimiento</h2>
                            <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm">Gráfico</div>
                        </div>
                        <div class="bg-gray-50 p-4 rounded-lg">

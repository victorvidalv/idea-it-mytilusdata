<%- include('../partials/header') %>

<!-- Agregar estas líneas justo después del include del header -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""></script>

<style>
    #centers-map {
        z-index: 1;
        height: 500px !important; /* Forzar altura */
        width: 100% !important;   /* Forzar ancho */
        position: relative !important; /* Asegurar posicionamiento */
        display: block !important; /* Forzar display */
    }
    .leaflet-container {
        border-radius: 0.75rem;
        width: 100% !important;
        height: 100% !important;
    }
</style>

<div class="min-h-screen bg-gradient-to-b from-gray-50 to-gray-100">
    <div class="py-12">
        <header>
            <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-center bg-white p-6 rounded-xl shadow-sm">
                    <div>
                        <h1 class="text-3xl font-bold leading-tight tracking-tight text-gray-900 mb-1">
                            Mis Centros
                        </h1>
                        <p class="text-gray-500 text-sm">Gestiona tus centros de cultivo</p>
                    </div>
                    <a href="/centers/new"
                        class="inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-blue-600 hover:bg-blue-700 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        Nuevo Centro
                    </a>
                </div>
            </div>
        </header>
        <main>
            <div class="mx-auto max-w-7xl sm:px-6 lg:px-8">
                <div class="px-4 py-8 sm:px-0 space-y-8">
                    <!-- Mapa de centros -->
                    <div class="bg-white overflow-hidden shadow-lg rounded-xl">
                        <div class="p-8">
                            <h2 class="text-xl font-semibold text-gray-900 mb-6 flex items-center">
                                <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                                        d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                                </svg>
                                Vista General de Centros
                            </h2>
                            <div id="centers-map" class="h-[500px] w-full rounded-xl border border-gray-200 shadow-inner"></div>
                        </div>
                    </div>

                    <!-- Lista de centros -->
                    <% if (centers && centers.length > 0) { %>
                        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                            <% centers.forEach(function(center) { %>
                                <div class="bg-white overflow-hidden shadow-lg rounded-xl transition-all duration-200 hover:shadow-xl hover:scale-[1.02]">
                                    <div class="p-6">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0 bg-blue-100 rounded-lg p-3">
                                                <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24"
                                                    stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                                </svg>
                                            </div>
                                            <div class="ml-5 w-0 flex-1">
                                                <h3 class="text-lg font-semibold text-gray-900 truncate">
                                                    <%= center.name %>
                                                </h3>
                                                <p class="mt-1 text-sm text-gray-500">
                                                    <%= center.location %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="bg-gray-50 px-6 py-4">
                                        <a href="/centers/<%= center.id %>"
                                            class="group flex items-center justify-center text-sm font-medium text-blue-600 hover:text-blue-700">
                                            Ver detalles
                                            <svg class="ml-2 w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                            </svg>
                                        </a>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="text-center bg-white p-12 rounded-xl shadow-lg">
                            <div class="bg-blue-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto">
                                <svg class="h-10 w-10 text-blue-600" fill="none" viewBox="0 0 24 24"
                                    stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                                </svg>
                            </div>
                            <h3 class="mt-4 text-lg font-semibold text-gray-900">No hay centros registrados</h3>
                            <p class="mt-2 text-gray-500">
                                Comienza creando un nuevo centro de cultivo para gestionar tus operaciones.
                            </p>
                            <div class="mt-8">
                                <a href="/centers/new"
                                    class="inline-flex items-center px-6 py-3 border border-transparent shadow-sm text-sm font-medium rounded-lg text-white bg-blue-600 hover:bg-blue-700 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                                    </svg>
                                    Crear Primer Centro
                                </a>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Asegurarnos de que el contenedor existe
    const mapContainer = document.getElementById('centers-map');
    if (!mapContainer) {
        console.error('No se encontró el contenedor del mapa');
        return;
    }

    try {
        // Inicializar mapa con opciones específicas
        const centersMap = L.map('centers-map', {
            zoomControl: true,
            scrollWheelZoom: true,
            dragging: true,
            minZoom: 6,  // Reducir zoom mínimo para vista más amplia
            maxZoom: 12   // Reducir zoom máximo para limitar acercamiento
        }).setView([-41.4720, -72.9429], 8);  // Reducir nivel de zoom inicial

        // Agregar capa base de OpenStreetMap
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(centersMap);

        // Agregar marcadores para cada centro si existen centros
        <% if (centers && centers.length > 0) { %>
            const markers = [];
            
            <% centers.forEach(function(center) { %>
                const marker = L.marker([<%= center.latitude %>, <%= center.longitude %>])
                    .bindPopup(`
                        <div style="text-align: center;">
                            <h3 style="font-weight: 600; color: #111827; margin-bottom: 4px;"><%= center.name %></h3>
                            <p style="color: #6B7280; font-size: 0.875rem; margin-bottom: 8px;"><%= center.location %></p>
                            <a href="/centers/<%= center.id %>" 
                               style="display: inline-block; background-color: #2563EB; color: white; padding: 6px 12px; 
                                      border-radius: 6px; text-decoration: none; font-size: 0.875rem; font-weight: 500;">
                                Ver detalles
                            </a>
                        </div>
                    `);
                markers.push(marker);
                marker.addTo(centersMap);
            <% }); %>

            // Ajustar vista para mostrar todos los marcadores
            if (markers.length > 0) {
                const group = L.featureGroup(markers);
                centersMap.fitBounds(group.getBounds().pad(0.1));
            }
        <% } %>

        // Forzar actualización del mapa
        setTimeout(() => {
            centersMap.invalidateSize();
        }, 100);

    } catch (error) {
        console.error('Error al inicializar el mapa:', error);
    }
});
</script>

<%- include('../partials/footer') %> 